# Mantle Ark uses Mantle official RPC by default.
# No API key, backend secret, wallet secret, or external indexer key is required.

# Optional override for local testing or a proxy RPC.
# NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.mantle.xyz

# Optional Cloudflare Workers AI oracle route.
# Leave unset to use the deterministic local oracle.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_TOKEN=
# CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
